@dataclass
class User:
    id:           str
    name:         str
    phone:        str            # 10-digit, E.164 normalised
    upi_id:       str
    aadhaar_hash: str            # SHA-256 of raw Aadhaar; raw number is NEVER stored
    platform:     Platform
    city:         str
    area:         str
    avg_weekly_earnings: float   # ₹
    tenure_months: int           # months on platform
    kyc_verified:  bool = False
    created_at:    datetime = field(default_factory=datetime.utcnow)
    policy_id:     Optional[str] = None


class RegistrationError(Exception):
    pass


class RegistrationManager:
    """
    Handles gig-worker onboarding:
      Step 1 — Phone + name capture  → send OTP
      Step 2 — OTP verification
      Step 3 — Aadhaar KYC + UPI linking
      Step 4 — Profile (platform, city, area, earnings)
      Step 5 — Commit user to DB
    """

    # ── Step 1: initiate OTP ──────────────────────────────────────────────────
    @staticmethod
    def send_otp(phone: str) -> str:
        """
        Validates phone format, generates a 6-digit OTP, stores it keyed by
        phone (in production: send via SMS gateway e.g. Twilio / MSG91).
        Returns the OTP (demo only — in prod this would be opaque).
        """
        phone = phone.strip().replace(" ", "")
        if not re.fullmatch(r"[6-9]\d{9}", phone):
            raise RegistrationError("Invalid Indian mobile number.")

        otp = str(random.randint(100000, 999999))
        _otps_db[phone] = otp
        # In production: send_sms(phone, f"Your GigShield OTP is {otp}. Valid for 5 min.")
        print(f"[OTP] Sent {otp} to +91-{phone}")
        return otp

    # ── Step 2: verify OTP ───────────────────────────────────────────────────
    @staticmethod
    def verify_otp(phone: str, entered_otp: str) -> bool:
        """
        Checks the entered OTP against the stored value.
        In production: also enforce expiry timestamp (5 minutes).
        """
        stored = _otps_db.get(phone)
        if not stored:
            raise RegistrationError("OTP not found or expired. Request a new one.")
        if stored != entered_otp.strip():
            raise RegistrationError("Incorrect OTP.")
        del _otps_db[phone]        # one-time use
        return True

    # ── Step 3: KYC verification ──────────────────────────────────────────────
    @staticmethod
    def verify_kyc(aadhaar_raw: str, upi_id: str) -> str:
        """
        Validates Aadhaar format and UPI ID.
        Hashes the Aadhaar with SHA-256 (raw number is immediately discarded).
        Returns the hash to store against the user record.

        In production: call UIDAI OTP-based e-KYC API or DigiLocker API.
        Enforce one-policy-per-Aadhaar uniqueness using the hash.
        """
        # Validate Aadhaar (12 digits, Luhn-like Verhoeff check skipped for brevity)
        aadhaar_clean = aadhaar_raw.replace(" ", "").replace("-", "")
        if not re.fullmatch(r"\d{12}", aadhaar_clean):
            raise RegistrationError("Aadhaar must be exactly 12 digits.")
        if not aadhaar_clean[0] in "23456789":     # VID/Aadhaar starts 2–9
            raise RegistrationError("Invalid Aadhaar number.")

        # Validate UPI (must contain @)
        if "@" not in upi_id or len(upi_id) < 5:
            raise RegistrationError("Invalid UPI ID — must contain '@'.")

        # Check for duplicate KYC
        aadhaar_hash = hashlib.sha256(aadhaar_clean.encode()).hexdigest()
        for existing in _users_db.values():
            if existing.aadhaar_hash == aadhaar_hash:
                raise RegistrationError("An account already exists for this Aadhaar.")

        return aadhaar_hash

    # ── Step 4 + 5: create user record ───────────────────────────────────────
    @staticmethod
    def create_user(
        name:              str,
        phone:             str,
        upi_id:            str,
        aadhaar_hash:      str,
        platform:          Platform,
        city:              str,
        area:              str,
        avg_weekly_earnings: float,
        tenure_months:     int = 6,
    ) -> User:
        """
        Commits a verified user to the data store.
        """
        if city not in CITY_RISK:
            raise RegistrationError(f"Unsupported city: {city}")
        if avg_weekly_earnings < 500:
            raise RegistrationError("Minimum reportable earnings are ₹500/week.")
        if tenure_months < 1:
            raise RegistrationError("Minimum platform tenure is 1 month.")

        user = User(
            id=str(uuid.uuid4()),
            name=name.strip(),
            phone=phone,
            upi_id=upi_id.strip(),
            aadhaar_hash=aadhaar_hash,
            platform=platform,
            city=city,
            area=area,
            avg_weekly_earnings=float(avg_weekly_earnings),
            tenure_months=int(tenure_months),
            kyc_verified=True,
        )
        _users_db[user.id] = user
        print(f"[Registration] User '{user.name}' registered — ID: {user.id}")
        return user

    @staticmethod
    def get_user(user_id: str) -> User:
        user = _users_db.get(user_id)
        if not user:
            raise RegistrationError(f"User '{user_id}' not found.")
        return user


