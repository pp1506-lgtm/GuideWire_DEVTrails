@dataclass
class ActiveTrigger:
    trigger_type:  TriggerType
    activated_at:  datetime
    activated_by:  str          # admin user ID or "system"
    deactivated_at: Optional[datetime] = None


@dataclass
class Claim:
    id:             str
    policy_id:      str
    user_id:        str
    trigger_type:   TriggerType
    amount:         float        # ₹ payout
    status:         ClaimStatus
    upi_id:         str          # destination for payout
    submitted_at:   datetime
    processed_at:   Optional[datetime] = None
    rejection_reason: Optional[str]    = None


# Global active-trigger registry (admin-controlled in the UI)
_active_triggers: dict[TriggerType, ActiveTrigger] = {}


class ClaimsError(Exception):
    pass


class TriggerManager:
    """Allows admins to activate / deactivate triggers."""

    @staticmethod
    def activate(trigger: TriggerType, admin_id: str = "admin"):
        _active_triggers[trigger] = ActiveTrigger(
            trigger_type=trigger,
            activated_at=datetime.utcnow(),
            activated_by=admin_id,
        )
        print(f"[Trigger] ACTIVATED: {trigger.value} by {admin_id}")

    @staticmethod
    def deactivate(trigger: TriggerType):
        if trigger in _active_triggers:
            _active_triggers[trigger].deactivated_at = datetime.utcnow()
            del _active_triggers[trigger]
            print(f"[Trigger] DEACTIVATED: {trigger.value}")

    @staticmethod
    def deactivate_all():
        for t in list(_active_triggers.keys()):
            TriggerManager.deactivate(t)

    @staticmethod
    def get_active() -> list[ActiveTrigger]:
        return list(_active_triggers.values())

    @staticmethod
    def is_active(trigger: TriggerType) -> bool:
        return trigger in _active_triggers


class ClaimsManager:
    """
    End-to-end claims pipeline:
      1. submit_claim   — validates eligibility, creates Claim record
      2. process_claim  — simulates UPI payout & marks claim PAID
      3. reject_claim   — admin/system rejection with reason
      4. get_history    — per-user claim history
    """

    COOLDOWN_HOURS = 1       # same trigger cannot be claimed twice within 1h

    # ── Eligibility check ─────────────────────────────────────────────────────
    @staticmethod
    def _check_eligibility(user: User, policy: Policy, trigger: TriggerType):
        # 1. Policy must be active
        if policy.status != PolicyStatus.ACTIVE:
            raise ClaimsError(f"Policy is {policy.status.value} — not eligible.")

        # 2. Trigger must be currently active (admin-fired)
        if not TriggerManager.is_active(trigger):
            raise ClaimsError(f"Trigger '{trigger.value}' is not currently active.")

        # 3. Trigger must be in policy's coverage list
        if trigger not in policy.trigger_coverage:
            raise ClaimsError(f"Trigger '{trigger.value}' is not covered by this policy.")

        # 4. Cooldown — no repeat claim for same trigger within cooldown window
        cutoff = datetime.utcnow() - timedelta(hours=ClaimsManager.COOLDOWN_HOURS)
        recent = [
            c for c in _claims_db.values()
            if c.user_id == user.id
            and c.trigger_type == trigger
            and c.submitted_at > cutoff
            and c.status != ClaimStatus.REJECTED
        ]
        if recent:
            raise ClaimsError(
                f"Already claimed '{trigger.value}' within "
                f"the last {ClaimsManager.COOLDOWN_HOURS}h."
            )

    # ── Submit ────────────────────────────────────────────────────────────────
    @staticmethod
    def submit_claim(
        user_id:      str,
        policy_id:    str,
        trigger:      TriggerType,
    ) -> Claim:
        """
        Validates all eligibility conditions and creates an APPROVED claim.
        In production, this would be queued for async payout processing.
        """
        user   = _users_db.get(user_id)
        policy = _policies_db.get(policy_id)

        if not user:
            raise ClaimsError(f"User '{user_id}' not found.")
        if not policy:
            raise ClaimsError(f"Policy '{policy_id}' not found.")

        ClaimsManager._check_eligibility(user, policy, trigger)

        payout = TRIGGER_PAYOUTS[trigger]
        claim  = Claim(
            id=f"CLM-{uuid.uuid4().hex[:8].upper()}",
            policy_id=policy_id,
            user_id=user_id,
            trigger_type=trigger,
            amount=payout,
            status=ClaimStatus.APPROVED,
            upi_id=user.upi_id,
            submitted_at=datetime.utcnow(),
        )
        _claims_db[claim.id] = claim

        print(f"[Claim] Submitted {claim.id} — ₹{payout} for "
              f"'{trigger.value}' → {user.upi_id}")
        return claim

    # ── Process (payout) ──────────────────────────────────────────────────────
    @staticmethod
    def process_claim(claim_id: str) -> Claim:
        """
        Executes the UPI payout.
        In production: call Razorpay / NPCI UPI payout API, handle webhook.
        """
        claim  = _claims_db.get(claim_id)
        if not claim:
            raise ClaimsError(f"Claim '{claim_id}' not found.")
        if claim.status != ClaimStatus.APPROVED:
            raise ClaimsError(f"Claim is {claim.status.value}, cannot process.")

        # Simulate UPI transfer
        claim.status       = ClaimStatus.PAID
        claim.processed_at = datetime.utcnow()

        # Update policy totals
        policy = _policies_db.get(claim.policy_id)
        if policy:
            policy.total_claimed += claim.amount
            policy.claim_count   += 1

        print(f"[Claim] PAID {claim_id} — ₹{claim.amount} → {claim.upi_id}")
        return claim

    # ── Reject ────────────────────────────────────────────────────────────────
    @staticmethod
    def reject_claim(claim_id: str, reason: str) -> Claim:
        claim = _claims_db.get(claim_id)
        if not claim:
            raise ClaimsError(f"Claim '{claim_id}' not found.")
        claim.status           = ClaimStatus.REJECTED
        claim.rejection_reason = reason
        claim.processed_at     = datetime.utcnow()
        print(f"[Claim] REJECTED {claim_id} — {reason}")
        return claim

    # ── History ───────────────────────────────────────────────────────────────
    @staticmethod
    def get_user_claims(user_id: str) -> list[Claim]:
        return sorted(
            [c for c in _claims_db.values() if c.user_id == user_id],
            key=lambda c: c.submitted_at, reverse=True,
        )

    @staticmethod
    def get_all_claims() -> list[Claim]:
        return sorted(_claims_db.values(), key=lambda c: c.submitted_at, reverse=True)

    @staticmethod
    def admin_summary() -> dict:
        all_claims = list(_claims_db.values())
        paid   = [c for c in all_claims if c.status == ClaimStatus.PAID]
        return {
            "total_claims":   len(all_claims),
            "total_paid_inr": sum(c.amount for c in paid),
            "paid_count":     len(paid),
            "active_triggers": [t.value for t in _active_triggers],
        }


