@dataclass
class Policy:
    id:            str
    user_id:       str
    status:        PolicyStatus
    weekly_premium: float        # ₹ — ML-computed
    city:          str
    area:          str
    platform:      Platform
    trigger_coverage: list[TriggerType]
    start_date:    datetime
    next_renewal:  datetime
    total_claimed: float = 0.0
    claim_count:   int   = 0
    created_at:    datetime = field(default_factory=datetime.utcnow)


class PolicyError(Exception):
    pass


class PolicyManager:
    """
    Manages the full lifecycle of a GigShield insurance policy:
      • Creation  — issued after successful registration + premium quote
      • Renewal   — weekly AutoPay (UPI Mandate)
      • Suspension / Cancellation
      • Retrieval / status check
    """

    @staticmethod
    def create_policy(user: User, weekly_premium: float) -> Policy:
        """
        Issues a new policy for a verified user with an ML-computed premium.
        """
        if not user.kyc_verified:
            raise PolicyError("Cannot issue policy without successful KYC.")
        if user.policy_id:
            existing = _policies_db.get(user.policy_id)
            if existing and existing.status == PolicyStatus.ACTIVE:
                raise PolicyError("User already has an active policy.")

        now = datetime.utcnow()
        policy = Policy(
            id=f"POL-{uuid.uuid4().hex[:10].upper()}",
            user_id=user.id,
            status=PolicyStatus.ACTIVE,
            weekly_premium=round(weekly_premium, 2),
            city=user.city,
            area=user.area,
            platform=user.platform,
            trigger_coverage=list(TriggerType),   # all 5 triggers covered
            start_date=now,
            next_renewal=now + timedelta(weeks=1),
        )
        _policies_db[policy.id] = policy
        user.policy_id = policy.id
        print(f"[Policy] Created {policy.id} for user {user.id} "
              f"@ ₹{policy.weekly_premium}/week")
        return policy

    @staticmethod
    def get_policy(policy_id: str) -> Policy:
        policy = _policies_db.get(policy_id)
        if not policy:
            raise PolicyError(f"Policy '{policy_id}' not found.")
        return policy

    @staticmethod
    def renew_policy(policy_id: str) -> Policy:
        """
        Processes weekly renewal via UPI AutoPay.
        In production: call Razorpay / PayU UPI Mandate charge API.
        """
        policy = PolicyManager.get_policy(policy_id)
        if policy.status != PolicyStatus.ACTIVE:
            raise PolicyError(f"Cannot renew a {policy.status.value} policy.")

        policy.next_renewal = datetime.utcnow() + timedelta(weeks=1)
        print(f"[Policy] Renewed {policy_id} — next renewal: {policy.next_renewal.date()}")
        return policy

    @staticmethod
    def cancel_policy(policy_id: str, reason: str = "") -> Policy:
        policy = PolicyManager.get_policy(policy_id)
        policy.status = PolicyStatus.CANCELLED
        print(f"[Policy] Cancelled {policy_id}. Reason: {reason or 'N/A'}")
        return policy

    @staticmethod
    def lapse_policy(policy_id: str) -> Policy:
        """Called when AutoPay fails (payment declined)."""
        policy = PolicyManager.get_policy(policy_id)
        policy.status = PolicyStatus.LAPSED
        print(f"[Policy] Lapsed {policy_id} — payment failure.")
        return policy

    @staticmethod
    def get_policy_summary(policy_id: str) -> dict:
        p = PolicyManager.get_policy(policy_id)
        user = _users_db.get(p.user_id, None)
        return {
            "policy_id":       p.id,
            "user_name":       user.name if user else "—",
            "status":          p.status.value,
            "weekly_premium":  f"₹{p.weekly_premium}",
            "city":            p.city,
            "area":            p.area,
            "platform":        p.platform.value,
            "triggers_covered": [t.value for t in p.trigger_coverage],
            "total_claimed":   f"₹{p.total_claimed}",
            "claim_count":     p.claim_count,
            "start_date":      str(p.start_date.date()),
            "next_renewal":    str(p.next_renewal.date()),
        }


